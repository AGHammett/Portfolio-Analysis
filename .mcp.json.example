{
  "mcpServers": {
    "sqlite": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "--yes",
        "mcp-server-sqlite"
      ],
      "env": {
        "SQLITE_DB_PATH": "C:\\path\\to\\Portfolio-Analysis\\data\\portfolio.db"
      }
    },
    "yfinance": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "C:/path/to/Portfolio-Analysis:/app",
        "portfolio-mcp",
        "python", "src/mcp_servers/yfinance_server.py"
      ]
    },
    "plotting": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "C:/path/to/Portfolio-Analysis:/app",
        "portfolio-mcp",
        "python", "src/mcp_servers/plotting_server.py"
      ]
    }
  }
}
